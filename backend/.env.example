# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
# Full Postgres connection string (takes precedence over individual vars below)
DATABASE_URL=postgresql://user:password@localhost:5432/triptailor_dev

# Individual Postgres vars (used when DATABASE_URL is not set)
PGHOST=localhost
PGPORT=5432
PGDATABASE=triptailor_dev
PGUSER=postgres
PGPASSWORD=

# ──────────────────────────────────────────────
# Auth
# ──────────────────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET_KEY=dev-secret-change-in-production

# ──────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000

# ──────────────────────────────────────────────
# External API Keys
# ──────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
YELP_API_KEY=

# ──────────────────────────────────────────────
# Ingestion Safety Controls
# ──────────────────────────────────────────────
INGEST_MAX_RESULTS=20
INGEST_RATE_LIMIT_SLEEP_SECONDS=0.2
